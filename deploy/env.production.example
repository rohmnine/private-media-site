# 复制为 deploy/.env（或项目根目录 .env），改成你自己的强口令后再部署。
# 四个密码必须互不相同，否则服务启动会报错。

MEDIA_HUB_PASSWORD=replace-with-long-access-password
MEDIA_HUB_VIEW_PASSWORD=replace-with-different-view-password
MEDIA_HUB_ADMIN_PASSWORD=replace-with-different-admin-password
MEDIA_HUB_DIARY_PASSWORD=replace-with-different-diary-password

# 会话签名密钥：至少 32 位随机字符（可用 `openssl rand -hex 32` 生成）。
SESSION_SECRET=replace-with-at-least-32-random-characters

# 公网 / HTTPS 访问时必须设为 true，让会话 Cookie 带上 Secure 标记（仅经 HTTPS 传输）。
# 仅本机 http 调试时设为 false。
COOKIE_SECURE=true

# 废弃区文件自动彻底删除的保留天数（设 0 关闭自动清理）。
MEDIA_HUB_TRASH_RETENTION_DAYS=30

# 单文件最大上传字节数（默认 8GiB）。
MEDIA_HUB_MAX_UPLOAD_BYTES=8589934592

# 滚动备份保留份数。
MEDIA_HUB_MAX_BACKUPS=50
